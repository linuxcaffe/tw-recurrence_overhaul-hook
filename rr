class RecurrenceManager:
    """Manage Taskwarrior enhanced recurrence"""
    
    def __init__(self):
        self.now = datetime.utcnow()
    
    def run_task_command(self, *args):
        """Run taskwarrior command and return output"""
        try:
            result = subprocess.run(
                ['task', 'rc.hooks=off'] + list(args),
                capture_output=True,
                text=True,
                check=True
            )
            return result.stdout
        except subprocess.CalledProcessError as e:
            print(f"Error running task command: {e}", file=sys.stderr)
            return None
    
    def get_templates(self):
        """Get all recurrence templates"""
        output = self.run_task_command('status:recurring', 'export')
        if not output:
            return []
        return json.loads(output)
    
    def get_template(self, uuid):
        """Get specific template by UUID"""
        output = self.run_task_command(uuid, 'export')
        if not output:
            return None
        tasks = json.loads(output)
        return tasks[0] if tasks else None
    
    def get_instances(self, template_uuid):
        """Get all instances for a template"""
        output = self.run_task_command(f'rtemplate:{template_uuid}', 'export')
        if not output:
            return []
        return json.loads(output)
    
    def cmd_templates(self):
        """Show all templates with enhanced formatting"""
        templates = self.get_templates()
        
        if not templates:
            print("No recurring task templates found.")
            return
        
        print(f"\n{'='*80}")
        print(f"RECURRING TASK TEMPLATES ({len(templates)} total)")
        print(f"{'='*80}\n")
        
        for t in templates:
            # Get instance count
            instances = self.get_instances(t['uuid'])
            pending = len([i for i in instances if i.get('status') in ['pending', 'waiting']])
            completed = len([i for i in instances if i.get('status') == 'completed'])
            
            print(f"ID:          task {t.get('id', 'N/A')}")
            print(f"Description: {t.get('description', 'N/A')}")
            print(f"Type:        {t.get('type', 'periodic')}")
            print(f"Recurrence:  {t.get('r', 'N/A')}")
            print(f"Anchor:      {t.get('ranchor', 'due')}")
            print(f"Last Index:  {t.get('rlast', 0)}")
            print(f"rlimit:      {t.get('rlimit', 1)}")
            
            if t.get('rend'):
                print(f"End Date:    {t.get('rend')}")
            
            print(f"Instances:   {pending} pending, {completed} completed")
            
            if t.get('project'):
                print(f"Project:     {t['project']}")
            if t.get('tags'):
                print(f"Tags:        {', '.join(t['tags'])}")
            
            print(f"UUID:        {t['uuid'][:8]}...")
            print(f"{'-'*80}\n")
    
    def cmd_template(self, uuid):
        """Show specific template with all instances"""
        template = self.get_template(uuid)
        if not template:
            print(f"Template {uuid} not found.")
            return
        
        instances = self.get_instances(uuid)
        
        print(f"\n{'='*80}")
        print(f"TEMPLATE: {template.get('description')}")
        print(f"{'='*80}\n")
        
        print(f"UUID:        {template['uuid']}")
        print(f"Type:        {template.get('type', 'periodic')}")
        print(f"Recurrence:  {template.get('r', 'N/A')}")
        print(f"Anchor:      {template.get('ranchor', 'due')}")
        print(f"Last Index:  {template.get('rlast', 0)}")
        print(f"rlimit:      {template.get('rlimit', 1)}")
        
        if template.get('project'):
            print(f"Project:     {template['project']}")
        if template.get('tags'):
            print(f"Tags:        {', '.join(template['tags'])}")
        
        print(f"\n{'='*80}")
        print(f"INSTANCES ({len(instances)} total)")
        print(f"{'='*80}\n")
        
        if not instances:
            print("No instances yet.")
            return
        
        # Sort by index
        instances.sort(key=lambda i: float(i.get('rindex', 0)))
        
        for i in instances:
            status = i.get('status', 'unknown')
            idx = i.get('rindex', 'N/A')
            desc = i.get('description', 'N/A')
            
            status_icon = {
                'pending': '[ ]',
                'waiting': '[w]',
                'completed': '[x]',
                'deleted': '[-]'
            }.get(status, '[?]')
            
            print(f"{status_icon} #{idx:<4} {status:<10} task {i.get('id', 'N/A'):<4} {desc}")
            
            if i.get('due'):
                print(f"         Due: {i['due']}")
            if i.get('end') and status == 'completed':
                print(f"         Completed: {i['end']}")
        
        print()
    
    def cmd_stats(self):
        """Show recurrence statistics"""
        templates = self.get_templates()
        
        if not templates:
            print("No recurring tasks found.")
            return
        
        total_templates = len(templates)
        by_type = defaultdict(int)
        by_period = defaultdict(int)
        total_instances = 0
        total_pending = 0
        total_completed = 0
        
        for t in templates:
            by_type[t.get('type', 'periodic')] += 1
            by_period[t.get('r', 'unknown')] += 1
            
            instances = self.get_instances(t['uuid'])
            total_instances += len(instances)
            total_pending += len([i for i in instances if i.get('status') in ['pending', 'waiting']])
            total_completed += len([i for i in instances if i.get('status') == 'completed'])
        
        print(f"\n{'='*80}")
        print("RECURRENCE STATISTICS")
        print(f"{'='*80}\n")
        
        print(f"Templates:        {total_templates}")
        print(f"  - Periodic:     {by_type.get('periodic', 0)}")
        print(f"  - Chained:      {by_type.get('chained', 0)}")
        print()
        
        print(f"Instances:        {total_instances}")
        print(f"  - Pending:      {total_pending}")
        print(f"  - Completed:    {total_completed}")
        print()
        
        print("Recurrence Periods:")
        for period, count in sorted(by_period.items(), key=lambda x: x[1], reverse=True):
            print(f"  - {period:<15} {count} template(s)")
        print()
    
    def cmd_check(self):
        """Check for recurrence data issues"""
        templates = self.get_templates()
        issues = []
        undeletable_tasks = []
        
        print("\nChecking recurrence data integrity...\n")
        
        for t in templates:
            uuid = t['uuid']
            desc = t.get('description', '(no description)')

            # Check for required fields
            if 'r' not in t:
                issues.append(f"Template {uuid[:8]} '{desc}' missing 'r' field")
            if 'type' not in t:
                issues.append(f"Template {uuid[:8]} '{desc}' missing 'type' field")
            if 'rlast' not in t:
                issues.append(f"Template {uuid[:8]} '{desc}' missing 'rlast' field")

            # Check instances
            instances = self.get_instances(uuid)
            instance_indices = [float(i.get('rindex', 0)) for i in instances if 'rindex' in i]

            if instances:
                # Check pending instance is in sync with template rlast
                pending = [i for i in instances if i.get('status') in ['pending', 'waiting']]
                rlast = int(float(t.get('rlast', 0)))
                for i in pending:
                    rindex = int(float(i.get('rindex', 0)))
                    if rindex != rlast:
                        issues.append(
                            f"Template {uuid[:8]} '{desc}' out of sync: "
                            f"rlast={rlast} but pending instance is rindex={rindex}"
                        )

                # Check for orphaned instances (wrong rtemplate pointer)
                for i in instances:
                    if i.get('rtemplate') != uuid:
                        issues.append(f"Instance {i.get('uuid', 'N/A')[:8]} '{i.get('description', '')}' has wrong rtemplate")

            # Check for childless template: no pending/waiting instance
            if query_instances is not None:
                pending = query_instances(uuid)
                if not pending:
                    task_id = t.get('id', '?')
                    issues.append(
                        f"Template '{t.get('description', uuid[:8])}' (task {task_id}) "
                        f"has no pending instance\n"
                        f"    -> fix: rr spawn {task_id}"
                    )
        
        # Check for orphaned instances (instance with no template)
        all_instances = json.loads(self.run_task_command('rtemplate.any:', 'export') or '[]')
        for i in all_instances:
            template_uuid = i.get('rtemplate')
            if template_uuid:
                template = self.get_template(template_uuid)
                if not template or template.get('status') != 'recurring':
                    issues.append(f"Instance {i.get('uuid', 'N/A')[:8]} '{i.get('description', '')}' is orphaned (template deleted)")
        
        # Check for undeletable tasks (deleted/completed with 'r' field)
        deleted_tasks = json.loads(self.run_task_command('status:deleted', 'r.any:', 'export') or '[]')
        completed_recurring = json.loads(self.run_task_command('status:completed', 'r.any:', 'export') or '[]')
        
        for task in deleted_tasks + completed_recurring:
            if 'r' in task and 'rtemplate' not in task:
                undeletable_tasks.append({
                    'uuid': task['uuid'],
                    'status': task['status'],
                    'description': task.get('description', 'N/A')
                })
                issues.append(f"Template {task['uuid'][:8]} '{task.get('description', '')}' is {task['status']} but still has 'r' field (undeletable)")
        
        if not issues:
            print("No issues found! Recurrence data is healthy.\n")
        else:
            print(f"Found {len(issues)} issue(s):\n")
            for issue in issues:
                print(f"  - {issue}")
            print()
            
            # Offer to fix undeletable tasks
            if undeletable_tasks:
                print(f"Found {len(undeletable_tasks)} undeletable task(s) that can be fixed.")
                print("These tasks have 'r' field but are deleted/completed, making them unpurgeable.")
                print("\nTasks to fix:")
                for task in undeletable_tasks:
                    print(f"  - {task['uuid'][:8]} ({task['status']}) {task['description']}")
                print()
                
                response = input("Remove 'r' field from these tasks to make them deletable? (yes/no): ")
                if response.lower() == 'yes':
                    fixed = 0
                    for task in undeletable_tasks:
                        try:
                            subprocess.run(
                                ['task', 'rc.hooks=off', 'rc.confirmation=off', task['uuid'], 'modify', 'r:'],
                                capture_output=True,
                                check=True
                            )
                            fixed += 1
                        except subprocess.CalledProcessError:
                            print(f"  Failed to fix {task['uuid'][:8]}")
                    
                    print(f"\nFixed {fixed} task(s). They can now be purged with: task purge\n")
                else:
                    print("Cancelled. Tasks remain undeletable.\n")
    def cmd_status(self):
        """Quick diagnostic: template/instance counts and any childless templates"""
        if query_instances is None:
            print("[!] recurrence_common_hook.py not found -- install recurrence-overhaul first.")
            return

        templates = self.get_templates()
        if not templates:
            print("No recurring templates found.")
            return

        childless = []
        for t in templates:
            if not query_instances(t['uuid']):
                childless.append(t)

        n_t = len(templates)
        n_i = n_t - len(childless)
        ok = len(childless) == 0
        marker = "[OK]" if ok else "[!] "

        print(f"Templates: {n_t}   Instances: {n_i}   {marker}")

        if childless:
            print()
            for t in childless:
                print(f"  Childless: '{t.get('description')}' (task {t.get('id', '?')})  -> rr spawn {t.get('id', '?')}")

    def cmd_dupe(self, id_or_uuid):
        """Duplicate a template (or demote an instance to a plain task)"""
        output = self.run_task_command(str(id_or_uuid), 'export')
        if not output:
            print(f"ERROR: Could not find task '{id_or_uuid}'.")
            return

        tasks = json.loads(output)
        if not tasks:
            print(f"ERROR: No task found for '{id_or_uuid}'.")
            return

        source = tasks[0]
        is_instance = 'rtemplate' in source
        is_template = source.get('status') == 'recurring' and 'r' in source

        if not is_instance and not is_template:
            print(f"ERROR: Task {id_or_uuid} is not a recurring template or instance.")
            return

        # Fields never copied regardless
        STRIP = {'uuid', 'id', 'entry', 'modified', 'status', 'end', 'urgency', 'rlast'}
        if is_instance:
            STRIP |= {'rtemplate', 'rindex'}

        # Build task add command
        cmd = ['task', 'rc.confirmation=off', 'rc.verbose=new-id', 'add',
               source['description']]

        annotations = []
        for field, value in source.items():
            if field in STRIP or field == 'description':
                continue
            if field == 'tags' and isinstance(value, list):
                cmd.extend([f'+{tag}' for tag in value])
            elif field == 'annotations' and isinstance(value, list):
                annotations = value  # handled after creation
            elif field == 'depends' and value:
                deps = ','.join(value) if isinstance(value, list) else value
                cmd.append(f'depends:{deps}')
            elif isinstance(value, (str, int, float)):
                cmd.append(f'{field}:{value}')

        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0:
            print(f"[!] task add failed: {result.stderr.strip()}")
            return

        # Extract new task ID for annotations
        new_id = None
        for line in result.stdout.splitlines():
            if 'Created task' in line:
                import re
                m = re.search(r'Created task (\d+)', line)
                if m:
                    new_id = m.group(1)
                    break

        if new_id and annotations:
            for ann in annotations:
                if isinstance(ann, dict) and 'description' in ann:
                    subprocess.run(
                        ['task', 'rc.hooks=off', 'rc.confirmation=off',
                         'rc.verbose=nothing', new_id, 'annotate', ann['description']],
                        capture_output=True
                    )

        desc = source.get('description', '')
        if is_template:
            print(f"[+] Duplicated template '{desc}' -- on-exit will spawn instance #1.")
        else:
            print(f"[+] Instance '{desc}' duplicated as standalone task (rtemplate/rindex stripped).")

    def cmd_spawn(self, id_or_uuid):
        """Spawn a missing instance for a childless template"""
        if spawn_instance is None or query_instances is None:
            print("ERROR: recurrence_common_hook.py not found in ~/.task/hooks/")
            print("  Ensure recurrence-overhaul is installed.")
            return

        output = self.run_task_command(str(id_or_uuid), 'export')
        if not output:
            print(f"ERROR: Could not find task '{id_or_uuid}'.")
            return

        tasks = json.loads(output)
        if not tasks:
            print(f"ERROR: No task found for '{id_or_uuid}'.")
            return

        template = tasks[0]
        if template.get('status') != 'recurring':
            print(f"ERROR: Task {id_or_uuid} is not a recurring template "
                  f"(status: {template.get('status', 'unknown')}).")
            print("  Use 'rr templates' to list templates.")
            return

        # Check for existing pending/waiting instance
        existing = query_instances(template['uuid'])
        if existing:
            inst = existing[0]
            print(f"[!] Template '{template.get('description')}' already has a pending instance:")
            print(f"    #{inst.get('rindex', '?')} (task {inst.get('id', '?')}) -- nothing to do.")
            return

        # Spawn next instance (rlast+1, or 1 if never spawned)
        next_index = int(template.get('rlast') or 0) + 1
        print(f"Spawning instance #{next_index} for '{template.get('description')}'...")

        msg = spawn_instance(template, next_index)
        if msg:
            print(f"[+] {msg}")
        else:
            print("[!] Spawn failed. Check template fields with 'rr template <uuid>'.")


def main():
    parser = argparse.ArgumentParser(
        description="Taskwarrior Recurrence Manager",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # templates command
    subparsers.add_parser('templates', help='Show all templates')
    
    # template command
    template_parser = subparsers.add_parser('template', help='Show specific template')
    template_parser.add_argument('uuid', help='Template UUID')
    
    # stats command
    subparsers.add_parser('stats', help='Show statistics')

    # check command
    subparsers.add_parser('check', help='Check data integrity')

    # status command
    subparsers.add_parser('status', help='Quick diagnostic: counts and childless templates')

    # spawn command
    spawn_parser = subparsers.add_parser('spawn', help='Spawn missing instance for a childless template')
    spawn_parser.add_argument('id', help='Template task ID or UUID')

    # dupe command
    dupe_parser = subparsers.add_parser('dupe', help='Duplicate a template or demote an instance to plain task')
    dupe_parser.add_argument('id', help='Template or instance task ID or UUID')

    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return
    
    manager = RecurrenceManager()
    
    if args.command == 'templates':
        manager.cmd_templates()
    elif args.command == 'template':
        manager.cmd_template(args.uuid)
    elif args.command == 'stats':
        manager.cmd_stats()
    elif args.command == 'check':
        manager.cmd_check()
    elif args.command == 'status':
        manager.cmd_status()
    elif args.command == 'spawn':
        manager.cmd_spawn(args.id)
    elif args.command == 'dupe':
        manager.cmd_dupe(args.id)
    else:
        parser.print_help()


if __name__ == '__main__':
    main()
